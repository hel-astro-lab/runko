{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 23,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "unix-cpu",
            "binaryDir": "${sourceDir}/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTING": "ON",
                "tyvi_ENABLE_IPO": "OFF",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "CMAKE_CXX_COMPILER": "mpic++",
                "tyvi_BACKEND": "cpu",
                "rocthrust_DIR": "$env{ROCTHRUST_INSTALL_PREFIX}/lib/cmake/rocthrust",
                "CMAKE_CXX_FLAGS": "-O3 -march=native -Wno-error=pass-failed"
            }
        },
        {
            "name": "macos-cpu",
            "binaryDir": "${sourceDir}/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTING": "ON",
                "tyvi_ENABLE_IPO": "OFF",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "CMAKE_CXX_COMPILER": "mpic++",
                "tyvi_BACKEND": "cpu",
                "rocthrust_DIR": "$env{ROCTHRUST_INSTALL_PREFIX}/lib/cmake/rocthrust",
                "CMAKE_CXX_FLAGS": "-O3 -march=native -mllvm -force-vector-width=4 -Wno-error=unused-command-line-argument -Wno-error=pass-failed -Wno-error=sign-conversion"
            }
        },
        {
            "name": "unix-gpu",
            "binaryDir": "${sourceDir}/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTING": "ON",
                "tyvi_ENABLE_IPO": "OFF",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "CMAKE_CXX_COMPILER": "hipcc",
                "tyvi_BACKEND": "hip",
                "OpenMP_CXX_FLAGS": "-fopenmp",
                "OpenMP_CXX_LIB_NAMES": "",
                "CMAKE_CXX_FLAGS": "-O3"
            }
        },
        {
            "name": "lumi-cpu",
            "binaryDir": "${sourceDir}/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTING": "ON",
                "tyvi_ENABLE_IPO": "OFF",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "CMAKE_CXX_COMPILER": "CC",
                "tyvi_BACKEND": "cpu",
                "rocthrust_DIR": "$env{ROCTHRUST_INSTALL_PREFIX}/lib/cmake/rocthrust",
                "CMAKE_CXX_FLAGS": "-O3"
            }
        },
        {
            "name": "hile-cpu",
            "binaryDir": "${sourceDir}/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTING": "ON",
                "tyvi_ENABLE_IPO": "OFF",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "CMAKE_CXX_COMPILER": "hipcc",
                "tyvi_BACKEND": "cpu",
                "rocthrust_DIR": "$env{ROCTHRUST_INSTALL_PREFIX}/lib/cmake/rocthrust",
                "CMAKE_CXX_FLAGS": "-O3 -march=znver3 -mtune=znver3 -funroll-loops -ffp-contract=fast -fno-math-errno"
            }
        },
        {
            "name": "lumi-gpu",
            "binaryDir": "${sourceDir}/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTING": "ON",
                "tyvi_ENABLE_IPO": "OFF",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "CMAKE_CXX_COMPILER": "CC",
                "tyvi_BACKEND": "hip",
                "OpenMP_CXX_FLAGS": "-fopenmp",
                "OpenMP_CXX_LIB_NAMES": "",
                "CMAKE_CXX_FLAGS": "-O3"
            }
        },
        {
            "name": "hile-gpu",
            "binaryDir": "${sourceDir}/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTING": "ON",
                "tyvi_ENABLE_IPO": "OFF",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "tyvi_BACKEND": "hip",
                "OpenMP_CXX_FLAGS": "-fopenmp",
                "OpenMP_CXX_LIB_NAMES": "",
                "CMAKE_CXX_FLAGS": "-O3",
                "CMAKE_CXX_COMPILER": "hipcc",
                "MPI_CXX_COMPILER": "CC"
            }
        }
    ]
}
