{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 23,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "conf-common",
            "description": "General settings that apply to all configurations",
            "hidden": true,
            "binaryDir": "${sourceDir}/${presetName}"
        },
        {
            "name": "conf-unixlike-common",
            "description": "Unix-like OS settings.",
            "hidden": true,
            "inherits": "conf-common",
            "condition": {
                "type": "inList",
                "string": "${hostSystemName}",
                "list": [
                    "Linux",
                    "Darwin"
                ]
            }
        },
        {
            "name": "macos-mpic++-debug",
            "displayName": "mpic++ Debug (macOS)",
            "description": "Target macOS with mpic++ (Homebrew clang++), cpu backend, debug build type.",
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "mpic++",
                "CMAKE_BUILD_TYPE": "Debug",
                "tyvi_ENABLE_IPO": "OFF",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "tyvi_BACKEND": "cpu",
                "rocthrust_DIR": "${sourceDir}/external/tyvi/rocm-libraries/projects/rocthrust/rocthrust-install/lib/cmake/rocthrust"
            }
        },
        {
            "name": "macos-mpic++-vec-analysis",
            "displayName": "mpic++ Vectorization Analysis (macOS)",
            "description": "Release build with SIMD vectorization diagnostics for auditing auto-vectorization.",
            "inherits": "macos-mpic++-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "-O3 -march=native -mllvm -force-vector-width=4 -Rpass=loop-vectorize -Rpass-missed=loop-vectorize -Rpass-analysis=loop-vectorize",
                "BUILD_TESTING": "ON"
            }
        },
        {
            "name": "conf-lumi-common",
            "description": "Common settings for LUMI supercomputer (AMD EPYC + MI250X).",
            "hidden": true,
            "inherits": "conf-unixlike-common",
            "cacheVariables": {
                "tyvi_ENABLE_IPO": "OFF",
                "tyvi_ENABLE_CLANG_TIDY": "OFF",
                "tyvi_ENABLE_CPPCHECK": "OFF",
                "BUILD_TESTING": "ON"
            }
        },
        {
            "name": "hile-cpu-release",
            "displayName": "HILE CPU Release (Cray clang)",
            "description": "HILE CPU partition, Cray C++ compiler (clang-based), optimized for AMD EPYC Zen 3.",
            "inherits": "conf-lumi-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "CC",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "-O3 -march=znver3 -mtune=znver3 -funroll-loops -ffp-contract=fast -fno-math-errno",
                "tyvi_BACKEND": "cpu"
            }
        },
        {
            "name": "lumi-gpu-release",
            "displayName": "LUMI GPU Release (hipcc + ROCm)",
            "description": "HILE GPU partition, Cray CC wrapper targeting MI250X (gfx90a), GPU-aware MPI.",
            "inherits": "conf-lumi-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "CC",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "-O3",
                "tyvi_BACKEND": "hip",
                "CMAKE_HIP_ARCHITECTURES": "gfx90a",
                "AMDGPU_TARGETS": "gfx90a",
                "GPU_TARGETS": "gfx90a",
                "OpenMP_CXX_FLAGS": "-fopenmp",
                "OpenMP_CXX_LIB_NAMES": ""
            }
        },
        {
            "name": "hile-gpu-release",
            "displayName": "HILE GPU Release (hipcc + ROCm)",
            "description": "HILE GPU partition, hipcc targeting MI210X (gfx90a), GPU-aware MPI.",
            "inherits": "conf-lumi-common",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "hipcc",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "-O3 --offload-arch=gfx90a -munsafe-fp-atomics",
                "tyvi_BACKEND": "hip",
                "CMAKE_HIP_ARCHITECTURES": "gfx90a",
                "AMDGPU_TARGETS": "gfx90a",
                "GPU_TARGETS": "gfx90a",
                "OpenMP_CXX_FLAGS": "-fopenmp",
                "OpenMP_CXX_LIB_NAMES": ""
            }
        }
    ],
    "testPresets": [
        {
            "name": "test-common",
            "description": "Test CMake settings that apply to all configurations",
            "hidden": true,
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": true
            }
        },
        {
            "name": "test-macos-mpic++-debug",
            "displayName": "mpic++ Debug (macOS)",
            "description": "Enable output and stop on failure",
            "inherits": "test-common",
            "configurePreset": "macos-mpic++-debug"
        },
        {
            "name": "test-macos-mpic++-vec-analysis",
            "displayName": "mpic++ Vectorization Analysis (macOS)",
            "description": "Enable output and stop on failure",
            "inherits": "test-common",
            "configurePreset": "macos-mpic++-vec-analysis"
        },
        {
            "name": "test-hile-cpu-release",
            "displayName": "HILE CPU Release",
            "description": "Enable output and stop on failure",
            "inherits": "test-common",
            "configurePreset": "hile-cpu-release"
        },
        {
            "name": "test-hile-gpu-release",
            "displayName": "HILE GPU Release",
            "description": "Enable output and stop on failure",
            "inherits": "test-common",
            "configurePreset": "hile-gpu-release"
        }
    ]
}
